# ==== ローカル資産（大容量・マシン依存。git 管理外） ====
/models/           # ローカル LLM モデル（VLM / テキスト LLM の .gguf 等）
/runtime/          # 外部エンジン（llama.cpp / kohya_ss / WebUI Forge）のインストール先

# ==== ユーザーデータ・生成物 ====
/projects/         # プロジェクトごとのデータセット・config・LoRA・出力
/data/             # ローカル設定・DB 等のランタイムデータ

# ==== Python (backend / kohya venv) ====
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==== Node / Electron / Vite (frontend) ====
node_modules/
dist/
dist-ssr/
out/
build/
release/
.vite/
*.local

# ==== ログ・一時ファイル ====
*.log
logs/
tmp/
*.tmp

# ==== OS / エディタ ====
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

